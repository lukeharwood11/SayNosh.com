# Copy this file to .env.local for local development, or .env.production for production builds.
#
# For local Supabase (run `supabase start` from project root first):
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=<your-local-publishable-key-from-supabase-start-output>

# For hosted/production Supabase:
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key

# PostHog (optional — omit for local/CI without analytics)
# VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_project_token
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Also turn on exception autocapture under Project settings → Error tracking (recommended).
